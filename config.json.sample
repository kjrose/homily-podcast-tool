{
  "openai_api_key": "your_openai_api_key_here",

  "ai": {
    "text_model": "gpt-5.4",
    "analysis_model": "gpt-5.4",
    "image_prompt_model": "gpt-5.4",
    "vtt_fallback_model": "gpt-5.4",
    "deviation_model": "gpt-5.4",
    "image_model": "gpt-image-1.5",
    "image_size": "1024x1024",
    "image_quality": "high"
  },

  "logging": {
    "log_dir": "logs",
    "hot_retention_days": 7,
    "archive_retention_days": 28,
    "cleanup_interval_hours": 6
  },

  "network": {
    "smtp_timeout_seconds": 30,
    "smtp_retry_attempts": 2,
    "smtp_retry_delay_seconds": 2,
    "wordpress_connect_timeout_seconds": 10,
    "wordpress_read_timeout_seconds": 60,
    "wordpress_retry_attempts": 2,
    "wordpress_retry_backoff_seconds": 2
  },

  "s3": {
    "endpoint": "your_s3_endpoint_url",
    "bucket": "your_s3_bucket_name",
    "folder": "your_s3_folder_prefix",
    "access_key": "your_s3_access_key",
    "secret_key": "your_s3_secret_key"
  },

  "paths": {
    "local_dir": "/path/to/local/directory",
    "batch_file": "/path/to/batch/file.bat",
    "db_path": "/path/to/homilies.db",
    "ffmpeg": "ffmpeg"
  },

  "church": {
    "timezone": "America/Edmonton"
  },

  "email": {
    "smtp_server": "smtp.example.com",
    "smtp_port": 587,
    "from": "sender@example.com",
    "to": "recipient@example.com",
    "user": "smtp_username",
    "password": "smtp_password",
    "subject": "Homily Processing Alert"
  },

  "wordpress": {
    "url": "https://yourwordpresssite.com",
    "user": "your_wp_username",
    "app_password": "your_wp_application_password"
  },

  "gpt_title_addon": "Ensure the title is inspirational and captures the essence of the Gospel message.",
  
  "gpt_description_addon": "Phrase the description in a welcoming, faith-building style that encourages listeners to reflect on their spiritual life.",
  
  "gpt_image_addon": "Prefer scene-driven sacred imagery that closely matches the homily, with strong composition and no visible words or lettering."
}
